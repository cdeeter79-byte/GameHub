{
  "name": "@gamehub/app",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "dev:web": "expo start --web",
    "dev:ios": "expo start --ios",
    "build": "expo export --platform web",
    "build:ios": "eas build --platform ios",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "typecheck": "tsc --noEmit",
    "lint": "eslint app/ src/",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --passWithNoTests --ci --coverage",
    "clean": "rm -rf dist .expo node_modules/.cache"
  },
  "dependencies": {
    "@gamehub/config": "workspace:*",
    "@gamehub/domain": "workspace:*",
    "@gamehub/ui": "workspace:*",
    "@gamehub/adapters": "workspace:*",
    "expo": "~52.0.23",
    "expo-router": "~4.0.17",
    "expo-status-bar": "~2.0.1",
    "expo-constants": "~17.0.4",
    "expo-notifications": "~0.29.12",
    "expo-linking": "~7.0.4",
    "expo-web-browser": "~14.0.2",
    "expo-auth-session": "~6.0.3",
    "expo-secure-store": "~14.0.1",
    "expo-splash-screen": "~0.29.18",
    "expo-font": "~13.0.3",
    "expo-image": "~2.0.4",
    "expo-location": "~18.0.5",
    "expo-haptics": "~14.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.5",
    "react-native-web": "~0.19.13",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-gesture-handler": "~2.21.2",
    "react-native-reanimated": "~3.16.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@supabase/supabase-js": "^2.47.10",
    "react-native-url-polyfill": "^2.0.0",
    "date-fns": "^4.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "babel-plugin-module-resolver": "^5.0.2",
    "typescript": "^5.7.2",
    "@types/react": "~18.3.12",
    "@types/react-dom": "~18.3.5",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.14",
    "ts-jest": "^29.2.5",
    "jest-expo": "~52.0.5"
  }
}
