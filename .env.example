# ============================================================
# GameHub Environment Variables — copy to .env and fill in
# ============================================================

# --- Supabase ---
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server/edge-functions only

# --- RevenueCat ---
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxx
EXPO_PUBLIC_REVENUECAT_WEB_KEY=rcb_xxxxx

# --- Stripe (manager billing) ---
STRIPE_SECRET_KEY=sk_test_xxxxx
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Stripe Price IDs — manager tiers
STRIPE_PRICE_STARTER_MONTHLY=price_xxxxx
STRIPE_PRICE_FAMILY_MONTHLY=price_xxxxx
STRIPE_PRICE_CLUB_MONTHLY=price_xxxxx
STRIPE_PRICE_STARTER_ANNUAL=price_xxxxx
STRIPE_PRICE_FAMILY_ANNUAL=price_xxxxx
STRIPE_PRICE_CLUB_ANNUAL=price_xxxxx

# --- Provider OAuth Credentials ---

# TeamSnap
TEAMSNAP_CLIENT_ID=
TEAMSNAP_CLIENT_SECRET=
EXPO_PUBLIC_TEAMSNAP_REDIRECT_URI=gamehub://auth/teamsnap/callback

# SportsEngine
SPORTSENGINE_CLIENT_ID=
SPORTSENGINE_CLIENT_SECRET=
EXPO_PUBLIC_SPORTSENGINE_REDIRECT_URI=gamehub://auth/sportsengine/callback

# LeagueApps
LEAGUEAPPS_CLIENT_ID=
LEAGUEAPPS_CLIENT_SECRET=
EXPO_PUBLIC_LEAGUEAPPS_REDIRECT_URI=gamehub://auth/leagueapps/callback

# PlayMetrics (API key auth — no OAuth)
# Keys are stored per-user in Supabase, not as env vars

# BAND (partner API — restricted access)
BAND_API_KEY=
BAND_CLIENT_TOKEN=

# --- Google (Maps + optional Calendar) ---
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_IOS=
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_WEB=

# --- Notifications ---
# Expo push notifications use Supabase Edge Functions
# No additional env var needed for Expo Go dev
# For production EAS builds:
EXPO_PUSH_TOKEN_ENCRYPTION_KEY=

# --- Feature Flags ---
EXPO_PUBLIC_ENABLE_ADS=false
EXPO_PUBLIC_ENABLE_BAND_INTEGRATION=false
EXPO_PUBLIC_ENABLE_MANAGER_MODE=true
EXPO_PUBLIC_ENABLE_EMAIL_IMPORT=true

# --- App Config ---
EXPO_PUBLIC_APP_ENV=development   # development | staging | production
EXPO_PUBLIC_SUPPORT_EMAIL=support@gamehub.app
